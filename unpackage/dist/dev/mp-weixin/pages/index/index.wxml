<view class="container"><block wx:if="{{isLoggedIn}}"><view class="header"><image class="avatar" src="{{userInfo.avatar||'/static/user.png'}}" mode="aspectFill"></image><text class="nickname">{{userInfo.nickname}}</text></view></block><block wx:else><view class="header"><view class="login-area"><text class="welcome-text">欢迎来到知识问答</text><button class="btn-login" loading="{{loginLoading}}" data-event-opts="{{[['tap',[['onLogin',['$event']]]]]}}" bindtap="__e">微信登录</button></view></view></block><block wx:if="{{isLoggedIn}}"><view class="cards mt-40"><view data-event-opts="{{[['tap',[['onStartQuiz',['$event']]]]]}}" class="card" bindtap="__e"><view class="card-icon">🎯</view><view class="card-content"><text class="card-title">开始答题</text><text class="card-desc">AI出题 · 10道精选题目 · 每题15秒</text></view></view><view data-event-opts="{{[['tap',[['onStartQuiz',['$event']]]]]}}" class="card" bindtap="__e"><view class="card-icon">📚</view><view class="card-content"><text class="card-title">常识问答</text><text class="card-desc">生活常识、历史地理</text></view></view><view data-event-opts="{{[['tap',[['onStartQuiz',['$event']]]]]}}" class="card" bindtap="__e"><view class="card-icon">🧪</view><view class="card-content"><text class="card-title">逻辑推理</text><text class="card-desc">找规律、智力测试</text></view></view></view></block><block wx:if="{{isLoggedIn}}"><view class="footer mt-40"><text class="footer-text">每次答题包含 5道常识 + 5道逻辑推理</text></view></block></view>