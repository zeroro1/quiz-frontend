
.header {
	display: flex;
	align-items: center;
	justify-content: center;
	padding: 40rpx 0;
}
.login-area {
	text-align: center;
	padding: 60rpx 0;
}
.welcome-text {
	display: block;
	font-size: 40rpx;
	font-weight: bold;
	margin-bottom: 40rpx;
	color: #333;
}
.avatar {
	width: 120rpx;
	height: 120rpx;
	border-radius: 50%;
	margin-right: 20rpx;
}
.nickname {
	font-size: 36rpx;
	font-weight: bold;
}
.btn-login {
	background: linear-gradient(135deg, #4CAF50, #66BB6A);
	color: #fff;
	border: none;
	border-radius: 50rpx;
	padding: 20rpx 60rpx;
	font-size: 32rpx;
}
.cards {
	display: flex;
	flex-direction: column;
}
.card {
	background: #fff;
	border-radius: 16rpx;
	padding: 40rpx;
	margin-bottom: 20rpx;
	box-shadow: 0 4rpx 16rpx rgba(0,0,0,0.08);
	display: flex;
	align-items: center;
}
.card-icon {
	font-size: 60rpx;
	margin-right: 24rpx;
}
.card-content {
	flex: 1;
}
.card-title {
	font-size: 32rpx;
	font-weight: bold;
	margin-bottom: 8rpx;
}
.card-desc {
	font-size: 24rpx;
	color: #999;
}
.footer {
	text-align: center;
}
.footer-text {
	font-size: 24rpx;
	color: #bbb;
}

