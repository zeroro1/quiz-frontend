<view class="container"><view class="tabs"><block wx:for="{{tabs}}" wx:for-item="item" wx:for-index="__i0__" wx:key="key"><view data-event-opts="{{[['tap',[['onTabChange',['$0'],[[['tabs','key',item.key,'key']]]]]]]}}" class="{{['tab',(activeTab===item.key)?'active':'']}}" bindtap="__e"><text>{{item.label}}</text></view></block></view><block wx:if="{{!loading}}"><view class="list"><block wx:for="{{$root.l0}}" wx:for-item="item" wx:for-index="__i1__" wx:key="userId"><view class="rank-item"><view class="{{['rank-num',(item.$orig.rank<=3)?'top3':'']}}">{{item.$orig.rank}}</view><view class="rank-info"><text class="rank-name">{{item.$orig.nickname||'匿名用户'}}</text><view class="rank-stats"><text class="stat">{{"正确率 "+item.$orig.accuracy+"%"}}</text><text class="stat">{{"平均 "+item.g0+"s/题"}}</text></view></view></view></block></view></block><block wx:if="{{$root.g1}}"><view class="empty"><text>暂无数据，快来答题吧！</text></view></block></view>