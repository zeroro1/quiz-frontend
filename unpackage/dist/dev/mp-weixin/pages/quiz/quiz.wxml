<view class="container"><block wx:if="{{loading}}"><view class="loading"><text>AI 正在出题...</text></view></block><block wx:else><block wx:if="{{!showResult}}"><view><view class="top-bar"><view class="progress-info"><text>{{"第 "+(currentIndex+1)+" / "+$root.g0+" 题"}}</text><text class="{{['timer-text',(timeLeft<=5)?'timer-warning':'']}}">{{"⏱ "+timeLeft+"s"}}</text></view><view class="progress-track"><view class="progress-fill" style="{{'width:'+((currentIndex+1)/$root.g1*100+'%')+';'}}"></view></view></view><view class="card question-card"><view class="{{['question-tag',currentQ.type==='COMMONSENSE'?'tag-commonsense':'tag-logic']}}">{{''+(currentQ.type==='COMMONSENSE'?'📚 常识':'🧩 逻辑')+''}}</view><text class="question-text">{{currentQ.content}}</text></view><view class="options"><block wx:for="{{$root.l0}}" wx:for-item="opt" wx:for-index="__i0__" wx:key="$orig"><view data-event-opts="{{[['tap',[['onAnswer',['$0'],[[['optionKeys','',__i0__]]]]]]]}}" class="{{['option',(answers[currentIndex]===opt.$orig)?'selected':'']}}" bindtap="__e"><text class="option-label">{{opt.$orig+"."}}</text><text class="option-content">{{opt.m0}}</text></view></block></view><view class="nav-buttons"><button class="btn-nav" disabled="{{currentIndex===0}}" data-event-opts="{{[['tap',[['onPrev',['$event']]]]]}}" bindtap="__e">上一题</button><button class="btn-nav" disabled="{{currentIndex===$root.g2-1}}" data-event-opts="{{[['tap',[['onNext',['$event']]]]]}}" bindtap="__e">下一题</button></view></view></block></block><block wx:if="{{showResult&&result}}"><view class="result-page"><view class="score-circle"><text class="score-number">{{$root.g3+"%"}}</text><text class="score-label">正确率</text></view><view class="result-details card"><view class="detail-row"><text>总题数</text><text>{{result.totalQuestions}}</text></view><view class="detail-row"><text>正确数</text><text>{{result.correctCount}}</text></view><view class="detail-row"><text>总用时</text><text>{{result.totalTime+"秒"}}</text></view></view><block wx:for="{{result.details}}" wx:for-item="item" wx:for-index="idx" wx:key="idx"><view class="answer-detail"><view class="{{['detail-header',item.isCorrect?'correct':'wrong']}}"><text>{{(item.isCorrect?'✅':'❌')+" 第"+(item.questionIndex+1)+"题"}}</text></view><text class="detail-question">{{item.content}}</text><text class="detail-answer">{{"你的答案: "+item.userAnswer+" | 正确答案: "+item.correctAnswer+" | 用时: "+item.timeTaken+"s"}}</text></view></block><button data-event-opts="{{[['tap',[['onRestart',['$event']]]]]}}" class="btn-restart" bindtap="__e">再来一局</button></view></block></view>