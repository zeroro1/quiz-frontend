<view class="container"><view class="title">我的答题记录</view><block wx:for="{{records}}" wx:for-item="item" wx:for-index="idx" wx:key="idx"><view class="record-item"><view class="{{['record-header',item.isCorrect?'correct':'wrong']}}"><text>{{item.isCorrect?'✅ 正确':'❌ 错误'}}</text><text>{{item.type==='COMMONSENSE'?'📚 常识':'🧩 逻辑'}}</text></view><text class="record-question">{{item.content}}</text><text class="record-answer">{{"你的答案: "+item.userAnswer+" | 正确: "+item.correctAnswer+" | 用时: "+item.timeTaken+"s"}}</text></view></block><block wx:if="{{$root.g0}}"><view class="empty"><text>还没有答题记录哦～</text></view></block></view>